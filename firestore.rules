rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Sessions — read/create open for unauthenticated audience + browser-mode presenters.
    // Update/delete on the session document itself is restricted to the owner.
    // Browser-mode sessions (ownerId == null) remain writable by anyone since
    // those presenters have no Google account to authenticate with.
    match /sessions/{code} {
      allow read, create: if true;
      allow update, delete: if
        resource.data.ownerId == null ||
        (request.auth != null && request.auth.uid == resource.data.ownerId);

      // Subcollections stay open — unauthenticated audience members and
      // browser-mode presenters both need full access here.
      match /responses/{responseId} {
        allow read, write: if true;
      }
      match /viewers/{viewerId} {
        allow read, write: if true;
      }
      match /reactions/{reactionId} {
        allow read, write: if true;
      }
    }

    // Shared deck links — public read (anyone with the URL can preview),
    // authenticated write (only signed-in users can create share links).
    match /sharedDecks/{shareId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // User decks and results — owner only.
    // The {document=**} wildcard covers nested sub-docs (results/latest)
    // so they inherit the same owner-only rule without a separate entry.
    match /users/{userId}/decks/{deckId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
